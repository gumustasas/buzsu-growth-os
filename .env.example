# Buzsu Growth OS — Environment Variables Şablonu
# Bu dosya örnektir. Gerçek değerler .env.local içine yazılır ve repoya commit EDİLMEZ.
# API anahtarları asla bu dosyaya yazılmaz — yalnızca anahtar İSİMLERİ belgelenir.

# =========================================================
# GLOBAL VERI MODU
# =========================================================
# true  → tüm connector'lar mock veri döner (varsayılan, güvenli)
# false → connector'lar live moduna geçer (ilgili ENABLE_* da true olmalı)
USE_MOCK_DATA=true

# =========================================================
# CONNECTOR AKTIVASYON BAYRAKLARI
# Bir connector'ın live çalışması için USE_MOCK_DATA=false VE ilgili bayrak true olmalı.
# =========================================================
ENABLE_AIRTABLE=false
ENABLE_SERPER=false
ENABLE_GSC=false
ENABLE_GA4=false
ENABLE_MERCHANT=false

# =========================================================
# AIRTABLE
# =========================================================
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=apphVqbUQohAMIoWk

# =========================================================
# SERPER (serper.dev)
# =========================================================
SERPER_API_KEY=
SERPER_GL=tr
SERPER_HL=tr

# =========================================================
# GOOGLE SEARCH CONSOLE
# =========================================================
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=
GSC_SITE_URL=https://www.buzsu.com.tr/

# =========================================================
# GOOGLE ANALYTICS 4
# =========================================================
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=

# =========================================================
# GOOGLE MERCHANT CENTER
# =========================================================
MERCHANT_CENTER_MERCHANT_ID=
GMC_CLIENT_EMAIL=
GMC_PRIVATE_KEY=
