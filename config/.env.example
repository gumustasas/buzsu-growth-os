# BUZSU Growth OS — Yapılandırma Değişkenleri Şablonu
#
# Bu dosya bir ŞABLON'dur. Gerçek değerleri buraya yazmayın.
# Kullanım:
#   1. Bu dosyayı kopyalayın: cp config/.env.example .env
#   2. .env dosyasına gerçek değerleri girin
#   3. .env dosyası repoya commit edilmez (.gitignore'da olmalı)
#
# Her değişken için açıklama ve format bilgisi aşağıda verilmiştir.

# ─────────────────────────────────────────────────────────
# SITE
# ─────────────────────────────────────────────────────────

# Ana site base URL — trailing slash olmadan
# Format: https://[domain]
# Örn: https://buzsu.com.tr
BUZSU_SITE_BASE_URL=

# Eğitim sitesi base URL
# Örn: https://suvesu.com
SUVESU_SITE_BASE_URL=

# ─────────────────────────────────────────────────────────
# GOOGLE SEARCH CONSOLE
# ─────────────────────────────────────────────────────────

# GSC'de tanımlı property URL'i (tam eşleşme)
# Format: https://[domain] veya sc-domain:[domain]
# Örn: https://buzsu.com.tr
GSC_PROPERTY_URL=

# ─────────────────────────────────────────────────────────
# AIRTABLE
# ─────────────────────────────────────────────────────────

# Buzsu Growth OS verisinin tutulduğu Airtable base ID'si
# Format: app[AlphanumericString]
# Değeri Airtable API > Base > API Documentation sayfasından alın
AIRTABLE_BASE_ID=

# ─────────────────────────────────────────────────────────
# N8N WEBHOOK'LAR
# (Yalnızca ilgili n8n workflow aktif ve insan onaylıysa kullanılır)
# ─────────────────────────────────────────────────────────

# JSON-LD şema doğrulama sonucunu alan n8n webhook URL'i
# Bu webhook şemayı canlıya almaz — yalnızca doğrulama raporunu iletir
# Format: https://[n8n-instance]/webhook/[uuid]
N8N_WEBHOOK_SCHEMA_VALIDATION=

# Aylık GSC raporunu Airtable'a ileten n8n webhook URL'i
# Yalnızca anonimleştirilmiş rapor verisi iletilir (PII yok)
# Format: https://[n8n-instance]/webhook/[uuid]
N8N_WEBHOOK_GSC_REPORT=

# ─────────────────────────────────────────────────────────
# SERPER (Opsiyonel — SERP araştırması için)
# ─────────────────────────────────────────────────────────

# Serper.dev API anahtarı — SEO SERP araştırması için
# Format: [32 karakter hex string]
SERPER_API_KEY=

# ─────────────────────────────────────────────────────────
# NOT
# ─────────────────────────────────────────────────────────
# Bu dosyaya gerçek değer eklemeyin.
# API anahtarı, token veya credential bu repoya commit edilmez.
# Bkz: CLAUDE.md — Güvenlik Kuralları
