# BUZSU Growth OS — Yapılandırma Değişkenleri Şablonu
#
# Bu dosya bir ŞABLON'dur. Gerçek değerleri buraya yazmayın.
# Kullanım:
#   1. Bu dosyayı kopyalayın: cp config/.env.example .env
#   2. .env dosyasına gerçek değerleri girin
#   3. .env dosyası repoya commit edilmez (.gitignore'da olmalı)

# ─────────────────────────────────────────────────────────
# SITE
# ─────────────────────────────────────────────────────────

# Ana site base URL — trailing slash olmadan
# Repo'dan doğrulandı: https://www.buzsu.com.tr (www dahil)
BUZSU_SITE_BASE_URL=

# Eğitim sitesi base URL
SUVESU_SITE_BASE_URL=

# ─────────────────────────────────────────────────────────
# DOĞRULANMIŞ ÜRÜN URL'LERİ (bilgi amaçlı — env variable değil)
# Bu path'ler repo'daki schema ve içerik dosyalarından doğrulandı:
#
#   /su-aritma-cihazlari/                                   (kategori)
#   /uv-filtreli-tezgah-alti-su-aritma-cihazi-pompali-model/ (ürün)
#   /code-su-aritma-cihazi/                                 (ürün)
#   /atiksiz-su-aritma-cihazi/                              (ürün)
#   /code-su-aritma-cihazi-5-li-filtre-seti-made-in-korea/  (filtre seti)
#   /tds-metre/                                             (aksesuar)
#
# DOĞRULANMAMIŞ — gerçek path'leri aşağıya girin:
# ─────────────────────────────────────────────────────────

# SSS / FAQ sayfası URL'i (repoda doğrulanamadı)
# Örn: https://www.buzsu.com.tr/sss/ veya /sikca-sorulan-sorular/
BUZSU_FAQ_URL=

# İletişim sayfası URL'i (repoda doğrulanamadı)
BUZSU_CONTACT_URL=

# Hakkımızda sayfası URL'i (repoda doğrulanamadı)
BUZSU_ABOUT_URL=

# Blog / içerik listesi URL'i (repoda doğrulanamadı)
BUZSU_BLOG_URL=

# ─────────────────────────────────────────────────────────
# GOOGLE SEARCH CONSOLE
# ─────────────────────────────────────────────────────────

# GSC'de tanımlı property URL'i (tam eşleşme)
# Format: https://www.buzsu.com.tr veya sc-domain:buzsu.com.tr
GSC_PROPERTY_URL=

# ─────────────────────────────────────────────────────────
# AIRTABLE
# ─────────────────────────────────────────────────────────

# Buzsu Growth OS verisinin tutulduğu Airtable base ID'si
# Format: app[AlphanumericString]
AIRTABLE_BASE_ID=

# ─────────────────────────────────────────────────────────
# N8N WEBHOOK'LAR
# (Sadece ilgili workflow aktif ve insan onaylıysa kullanılır)
# ─────────────────────────────────────────────────────────

# JSON-LD schema doğrulama raporunu alan webhook
# NOT: Şemayı canlıya almaz — yalnızca doğrulama raporunu iletir
N8N_WEBHOOK_SCHEMA_VALIDATION=

# Aylık GSC raporunu Airtable'a ileten webhook
# NOT: Yalnızca anonimleştirilmiş rapor verisi iletilir (PII yok)
N8N_WEBHOOK_GSC_REPORT=

# ─────────────────────────────────────────────────────────
# SERPER (Opsiyonel — SERP araştırması için)
# ─────────────────────────────────────────────────────────

SERPER_API_KEY=

# ─────────────────────────────────────────────────────────
# NOT
# Bu dosyaya gerçek değer eklemeyin.
# Bkz: CLAUDE.md — Güvenlik Kuralları
# ─────────────────────────────────────────────────────────
